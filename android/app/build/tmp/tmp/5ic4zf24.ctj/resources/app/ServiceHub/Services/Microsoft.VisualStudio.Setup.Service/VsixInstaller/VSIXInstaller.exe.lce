      <Item ItemId=";ErrorExtensionSdkModificationCausingMultipleTargets" ItemType="0" PsrId="211" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[Please schedule extension SDK modifications separately from other extensions.]]></Val>
        </Str>
