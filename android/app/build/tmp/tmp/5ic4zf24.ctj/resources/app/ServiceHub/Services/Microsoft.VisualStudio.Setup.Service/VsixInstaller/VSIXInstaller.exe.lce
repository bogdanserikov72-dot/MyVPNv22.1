      <Item ItemId=";ErrorCorruptInstance" ItemType="0" PsrId="211" InstFlg="true" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[VSIX Installer has encountered a problem. To troubleshoot, follow the steps here: {0}]]></Val>
